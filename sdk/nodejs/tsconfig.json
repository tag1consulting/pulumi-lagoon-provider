{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "config/index.ts",
        "config/vars.ts",
        "index.ts",
        "lagoon/deployTarget.ts",
        "lagoon/deployTargetConfig.ts",
        "lagoon/environment.ts",
        "lagoon/environmentAutogeneratedRouteConfig.ts",
        "lagoon/group.ts",
        "lagoon/index.ts",
        "lagoon/notificationEmail.ts",
        "lagoon/notificationMicrosoftTeams.ts",
        "lagoon/notificationRocketChat.ts",
        "lagoon/notificationSlack.ts",
        "lagoon/project.ts",
        "lagoon/projectAutogeneratedRouteConfig.ts",
        "lagoon/projectNotification.ts",
        "lagoon/route.ts",
        "lagoon/task.ts",
        "lagoon/user.ts",
        "lagoon/userGroupAssignment.ts",
        "lagoon/userPlatformRole.ts",
        "lagoon/variable.ts",
        "provider.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
