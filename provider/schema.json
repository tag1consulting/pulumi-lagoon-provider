    "lagoon:lagoon:Task": {
      "description": "Manages a Lagoon advanced task definition.",
      "properties": {
        "arguments": {
          "type": "array",
          "items": {
            "$ref": "#/types/lagoon:resources:TaskArgumentInput"
          },
          "description": "List of argument definitions for the task."
        },
        "command": {
          "type": "string",
          "description": "Command to execute (required for 'command' type)."
        },
        "confirmationText": {
          "type": "string",
          "description": "Text to display for user confirmation."
        },
        "created": {
          "type": "string"
        },
        "description": {
          "type": "string",
