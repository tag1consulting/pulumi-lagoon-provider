        },
        "deployTargetId": {
          "type": "integer",
          "description": "The deploy target (Kubernetes cluster) ID."
        },
        "deployTargetProjectPattern": {
          "type": "string",
          "description": "Optional namespace pattern."
        },
        "lagoonId": {
          "type": "integer"
        },
        "projectId": {
          "type": "integer",
          "description": "The project ID."
        },
        "pullrequests": {
          "type": "string",
          "description": "Whether to handle PRs ('true' or 'false')."
        },
        "weight": {
          "type": "integer",
          "description": "Priority weight (higher = more priority)."
        }
      },
      "required": [
        "projectId",
        "deployTargetId",
        "lagoonId"
