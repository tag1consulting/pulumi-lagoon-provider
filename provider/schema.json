  "resources": {
    "lagoon:lagoon:DeployTarget": {
      "description": "Manages a Lagoon Kubernetes deploy target (cluster).",
      "properties": {
        "buildImage": {
          "type": "string",
          "description": "Custom build image."
        },
        "cloudProvider": {
          "type": "string",
          "description": "Cloud provider (e.g., 'kind', 'aws', 'gcp'). Defaults to 'kind'."
        },
        "cloudRegion": {
          "type": "string",
          "description": "Cloud region (e.g., 'us-east-1', 'local'). Defaults to 'local'."
        },
        "consoleUrl": {
          "type": "string",
          "description": "The Kubernetes API URL."
        },
        "created": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether the deploy target is disabled."
        },
        "lagoonId": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "description": "The deploy target name."
        },
        "routerPattern": {
          "type": "string",
          "description": "Router pattern for the deploy target."
        },
        "sshHost": {
          "type": "string",
          "description": "SSH host for builds."
        },
        "sshPort": {
          "type": "string",
          "description": "SSH port for builds."
        }
      },
      "required": [
        "name",
        "consoleUrl",
        "lagoonId",
        "created"
      ],
