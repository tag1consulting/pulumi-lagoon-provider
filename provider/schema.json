        },
        "environmentId": {
          "type": "integer",
          "description": "Environment ID (for environment-scoped tasks)."
        },
        "groupName": {
          "type": "string",
          "description": "Group name (for group-scoped tasks)."
        },
        "image": {
          "type": "string",
          "description": "Container image to run (required for 'image' type)."
        },
        "lagoonId": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "description": "The task definition name."
        },
        "permission": {
          "type": "string",
          "description": "Permission level: 'guest', 'developer', or 'maintainer'."
        },
        "projectId": {
          "type": "integer",
          "description": "Project ID (for project-scoped tasks)."
        },
        "service": {
          "type": "string",
          "description": "Service container name to run the task in."
        },
        "systemWide": {
          "type": "boolean",
          "description": "If true, task is available system-wide (platform admin only)."
        },
        "type": {
          "type": "string",
          "description": "Task type: 'command' or 'image'."
