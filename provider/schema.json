{
  "name": "lagoon",
  "displayName": "Lagoon",
  "version": "0.2.0-dev",
  "description": "Manage Lagoon hosting platform resources as infrastructure-as-code.",
  "keywords": [
    "lagoon",
    "hosting",
    "kubernetes",
    "pulumi"
  ],
  "homepage": "https://github.com/tag1consulting/pulumi-lagoon-provider",
  "license": "Apache-2.0",
  "repository": "https://github.com/tag1consulting/pulumi-lagoon-provider",
  "pluginDownloadURL": "https://github.com/tag1consulting/pulumi-lagoon-provider/releases/download/v${VERSION}",
  "publisher": "Tag1 Consulting",
  "language": {
    "go": {
      "generateExtraInputTypes": true,
      "generateResourceContainerTypes": true,
      "importBasePath": "github.com/tag1consulting/pulumi-lagoon-provider/sdk/go/lagoon"
    },
    "nodejs": {
      "packageName": "@tag1consulting/pulumi-lagoon",
      "respectSchemaVersion": true
    },
    "python": {
      "packageName": "pulumi_lagoon",
      "pyproject": {
        "enabled": true
      },
      "respectSchemaVersion": true
    }
  },
  "config": {
    "variables": {
      "apiUrl": {
        "type": "string",
        "description": "The Lagoon GraphQL API endpoint URL.",
        "default": "https://api.lagoon.sh/graphql",
        "defaultInfo": {
          "environment": [
            "LAGOON_API_URL"
          ]
        },
        "secret": true
      },
      "insecure": {
        "type": "boolean",
        "description": "Disable SSL certificate verification when connecting to the Lagoon API.",
        "default": false,
        "defaultInfo": {
          "environment": [
            "LAGOON_INSECURE"
          ]
        }
      },
      "jwtAudience": {
        "type": "string",
        "description": "The audience claim for generated JWT tokens. Defaults to 'api.dev'.",
        "default": "api.dev",
        "defaultInfo": {
          "environment": [
            "LAGOON_JWT_AUDIENCE"
          ]
        }
      },
      "jwtSecret": {
        "type": "string",
        "description": "The Lagoon core JWTSECRET. Used to generate admin tokens on-the-fly.",
        "defaultInfo": {
          "environment": [
            "LAGOON_JWT_SECRET"
          ]
        },
        "secret": true
      },
      "token": {
        "type": "string",
        "description": "A pre-configured JWT authentication token for the Lagoon API.",
        "defaultInfo": {
          "environment": [
            "LAGOON_TOKEN"
          ]
        },
        "secret": true
      }
    }
  },
  "types": {
    "lagoon:resources:TaskArgumentInput": {
      "properties": {
        "displayName": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "name",
        "displayName",
        "type"
      ]
    }
  },
  "provider": {
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "The Lagoon GraphQL API endpoint URL.",
        "default": "https://api.lagoon.sh/graphql",
        "defaultInfo": {
          "environment": [
            "LAGOON_API_URL"
          ]
        },
        "secret": true
      },
      "insecure": {
        "type": "boolean",
        "description": "Disable SSL certificate verification when connecting to the Lagoon API.",
        "default": false,
        "defaultInfo": {
          "environment": [
            "LAGOON_INSECURE"
          ]
        }
      },
      "jwtAudience": {
        "type": "string",
        "description": "The audience claim for generated JWT tokens. Defaults to 'api.dev'.",
        "default": "api.dev",
        "defaultInfo": {
          "environment": [
            "LAGOON_JWT_AUDIENCE"
          ]
        }
      },
      "jwtSecret": {
        "type": "string",
        "description": "The Lagoon core JWTSECRET. Used to generate admin tokens on-the-fly.",
        "defaultInfo": {
          "environment": [
            "LAGOON_JWT_SECRET"
          ]
        },
        "secret": true
      },
      "token": {
        "type": "string",
        "description": "A pre-configured JWT authentication token for the Lagoon API.",
        "defaultInfo": {
          "environment": [
            "LAGOON_TOKEN"
          ]
        },
        "secret": true
      }
    },
    "inputProperties": {
      "apiUrl": {
        "type": "string",
        "description": "The Lagoon GraphQL API endpoint URL.",
        "default": "https://api.lagoon.sh/graphql",
        "defaultInfo": {
          "environment": [
            "LAGOON_API_URL"
          ]
        },
        "secret": true
      },
      "insecure": {
        "type": "boolean",
        "description": "Disable SSL certificate verification when connecting to the Lagoon API.",
        "default": false,
        "defaultInfo": {
          "environment": [
            "LAGOON_INSECURE"
          ]
        }
      },
      "jwtAudience": {
        "type": "string",
        "description": "The audience claim for generated JWT tokens. Defaults to 'api.dev'.",
        "default": "api.dev",
        "defaultInfo": {
          "environment": [
            "LAGOON_JWT_AUDIENCE"
          ]
