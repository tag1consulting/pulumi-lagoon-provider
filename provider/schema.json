        },
        "cloudRegion": {
          "type": "string",
          "description": "Cloud region (e.g., 'us-east-1', 'local'). Defaults to 'local'."
        },
        "consoleUrl": {
          "type": "string",
          "description": "The Kubernetes API URL."
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether the deploy target is disabled."
        },
        "name": {
          "type": "string",
          "description": "The deploy target name."
        },
        "routerPattern": {
          "type": "string",
          "description": "Router pattern for the deploy target."
